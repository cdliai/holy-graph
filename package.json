{
  "name": "@cdli/holy-graph",
  "version": "0.1.0-phase-0",
  "private": true,
  "description": "A 3D visualization that replays a codebase's git history commit by commit.",
  "keywords": [
    "git",
    "visualization",
    "codebase",
    "3d",
    "three.js",
    "cli"
  ],
  "homepage": "https://holygraph.cdli.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cdliai/holy-graph.git"
  },
  "bugs": {
    "url": "https://github.com/cdliai/holy-graph/issues"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": "Fatih Burak Karagöz <higlited@gmail.com> (CDLI)",
  "type": "module",
  "bin": {
    "holy-graph": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "extract": "tsx src/extract/index.ts",
    "dev": "vite",
    "build": "pnpm build:renderer && pnpm build:cli",
    "build:renderer": "vite build",
    "build:cli": "tsup && chmod +x dist/cli/index.js",
    "preview": "vite preview",
    "test": "pnpm build && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "d3-force-3d": "^3.0.5",
    "three": "^0.163.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/three": "^0.163.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vite-plugin-singlefile": "^2.0.0",
    "vitest": "^1.6.0"
  }
}
